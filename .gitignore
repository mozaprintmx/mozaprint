# =============================================================================
# Secrets y credenciales
# =============================================================================

# Nunca commitear API keys
.env
.env.local
.env.*.local
secrets/
*.key
*.pem
credentials.json

# =============================================================================
# Datos sensibles del cliente
# =============================================================================

# Exports de WhatsApp (siempre tienen PII)
whatsapp-exports/
*.whatsapp_export.txt
*-chat.txt

# Backups con datos reales
backups/
*.sql
*.dump

# Datos reales de prueba
test/real-data/
test/private/

# Exports de Odoo con datos
*_export_*.json
*_export_*.csv

# Reportes de auditoría de catálogo (JSON + MD): repo público, contienen
# nombres de pricelist tipo cliente y métricas de negocio. NO se commitean.
reports/catalog_audit_*

# =============================================================================
