n8n-executions/
*.execution.json

# =============================================================================
# Editor / IDE
# =============================================================================

.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# Logs
# =============================================================================

logs/
*.log
*.log.*

# =============================================================================
# Claude Code
# =============================================================================

# Memoria local de Claude Code (proyecto-específica)
.claude/*                    # (1) esencial: ignora el contenido directo
!.claude/rules/              # (2) esencial: rescata la carpeta de reglas
!.claude/rules/**            # (3) redundante con (2), pero documenta intención
.claude/settings.local.json  # (4) redundante con (1), pero deja claro qué NO subir
.claude-memory/

# CLAUDE.local.md es para preferencias personales del operador,
# no se commitea
CLAUDE.local.md

# =============================================================================
# Sistema operativo
# =============================================================================

.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Anonimización temporal
# =============================================================================

# Archivos en proceso de anonimización (antes de validar)
anonymized/staging/

# =============================================================================
# Snapshots y diffs
# =============================================================================

snapshots/
diffs/
*.diff.json
